PORT=8000
NODE_ENV=development

DATABASE_URL="postgresql://your_db_user:your_db_password@your_db_host:5432/your_db_name?sslmode=require"

JWT_ACCESS_SECRET="your-jwt-access-token-secret-key"
JWT_REFRESH_SECRET="your-jwt-refresh-token-secret-key"

GOOGLE_CLIENT_ID="your-google-oauth-client-id"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"

CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

GEMINI_API_KEY="your-gemini-api-key"

